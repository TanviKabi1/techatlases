generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Region {
  id         String      @id @default(uuid())
  name       String      @unique
  continent  String?
  createdAt  DateTime    @default(now()) @map("created_at")
  companies  Company[]
  developers Developer[]

  @@map("region")
}

model Company {
  id           String        @id @default(uuid())
  name         String
  size         String?
  industry     String?
  regionId     String?       @map("region_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  region       Region?       @relation(fields: [regionId], references: [id])
  workProfiles WorkProfile[]

  @@index([regionId], map: "company_region_id_fkey")
  @@map("company")
}

model TechCategory {
  id              String       @id @default(uuid())
  name            String       @unique
  description     String?
  popularityScore Decimal?     @default(0.000000000000000000000000000000) @map("popularity_score")
  createdAt       DateTime     @default(now()) @map("created_at")
  technologies    Technology[]

  @@map("tech_category")
}

model Technology {
  id            String          @id @default(uuid())
  name          String          @unique
  categoryId    String?         @map("category_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  developerTech DeveloperTech[]
  category      TechCategory?   @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "technology_category_id_fkey")
  @@map("technology")
}

model AITool {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  usersAi     UsesAI[]

  @@map("ai_tool")
}

model Developer {
  id             String          @id @default(uuid())
  name           String?
  email          String?
  age            Int?
  country        String?
  regionId       String?         @map("region_id")
  yearsCoding    Int?            @map("years_coding")
  educationLevel String?         @map("education_level")
  createdAt      DateTime        @default(now()) @map("created_at")
  region         Region?         @relation(fields: [regionId], references: [id])
  developerTech  DeveloperTech[]
  aiUsage        UsesAI[]
  workProfile    WorkProfile?

  @@index([regionId], map: "developers_region_id_fkey")
  @@map("developers")
}

model WorkProfile {
  id             String    @id @default(uuid())
  developerId    String    @unique @map("developer_id")
  companyId      String?   @map("company_id")
  jobRole        String?   @map("job_role")
  employmentType String?   @map("employment_type")
  salary         Decimal?
  remoteWork     String?   @map("remote_work")
  createdAt      DateTime  @default(now()) @map("created_at")
  company        Company?  @relation(fields: [companyId], references: [id])
  developer      Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@index([companyId], map: "work_profile_company_id_fkey")
  @@map("work_profile")
}

model DeveloperTech {
  id           String     @id @default(uuid())
  developerId  String     @map("developer_id")
  technologyId String     @map("technology_id")
  proficiency  Int?       @default(1)
  yearsUsed    Int?       @default(0) @map("years_used")
  createdAt    DateTime   @default(now()) @map("created_at")
  developer    Developer  @relation(fields: [developerId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@unique([developerId, technologyId])
  @@index([technologyId], map: "developers_tech_technology_id_fkey")
  @@map("developers_tech")
}

model UsesAI {
  id            String    @id @default(uuid())
  developerId   String    @map("developer_id")
  aiToolId      String    @map("ai_tool_id")
  sentiment     String?
  useCase       String?   @map("use_case")
  adoptionScore Int?      @default(0) @map("adoption_score")
  createdAt     DateTime  @default(now()) @map("created_at")
  aiTool        AITool    @relation(fields: [aiToolId], references: [id], onDelete: Cascade)
  developer     Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@unique([developerId, aiToolId])
  @@index([aiToolId], map: "uses_ai_ai_tool_id_fkey")
  @@map("uses_ai")
}

model RawSurveyData {
  id          String    @id @default(uuid())
  rawJson     Json      @map("raw_json")
  processed   Boolean?  @default(false)
  importedAt  DateTime  @default(now()) @map("imported_at")
  processedAt DateTime? @map("processed_at")

  @@map("raw_survey_data")
}

model User {
  id          String            @id @default(uuid())
  email       String            @unique
  password    String
  createdAt   DateTime          @default(now()) @map("created_at")
  profile     Profile?
  savedTech   SavedTechnology[]
  savedTrends SavedTrend[]
  roadmap     UserRoadmap[]
  roles       UserRole[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Profile {
  id          String   @id @map("id")
  email       String?
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model NewspaperMessage {
  id          String   @id @default(uuid())
  displayName String?  @map("display_name")
  message     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("newspaper_messages")
}

model SavedTechnology {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  technologyName String   @map("technology_name")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "saved_technologies_user_id_fkey")
  @@map("saved_technologies")
}

model SavedTrend {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  trendName     String   @map("trend_name")
  trendCategory String?  @map("trend_category")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "saved_trends_user_id_fkey")
  @@map("saved_trends")
}

model UserRoadmap {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  technologyName String   @map("technology_name")
  status         String   @default("planned")
  createdAt      DateTime @default(now()) @map("created_at")
  progress       Int?     @default(0)
  priority       Int?     @default(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "user_roadmap_user_id_fkey")
  @@map("user_roadmap")
}
